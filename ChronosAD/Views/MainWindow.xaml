<Window x:Class="ChronosAD.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ChronosAD — Timeclock"
        Width="860" Height="680"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#0F3460">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ChronosAD" FontSize="22" FontWeight="Bold" Foreground="#E94560"/>
                    <TextBlock x:Name="TxtWelcome" FontSize="13" Foreground="#B0BEC5"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnManagement" Content="Management" Width="130" Height="36"
                            Background="#E94560" Style="{StaticResource BaseButton}"
                            Click="BtnManagement_Click" Visibility="Collapsed" Margin="0,0,10,0"/>
                    <Button Content="Refresh" Width="90" Height="36"
                            Background="#37474F" Style="{StaticResource BaseButton}"
                            Click="BtnRefresh_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel -->
            <StackPanel Grid.Column="0" VerticalAlignment="Top">

                <!-- Clock Button -->
                <Border Background="#0F3460" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="TxtStatus" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="White" Margin="0,0,0,12"/>
                        <TextBlock x:Name="TxtCurrentTime" FontSize="28" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="#E94560" Margin="0,0,0,12"/>
                        <Button x:Name="BtnPunch" Height="70" Width="200" FontSize="18"
                                Style="{StaticResource BaseButton}"
                                Click="BtnPunch_Click" Margin="0,0,0,12"/>
                        <Button Content="Attach Note" Height="36" Width="200"
                                Background="#37474F" Style="{StaticResource BaseButton}"
                                Click="BtnNote_Click"/>
                    </StackPanel>
                </Border>

                <!-- Hours Summary -->
                <Border Background="#0F3460" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Current Pay Period" FontSize="13" Foreground="#B0BEC5" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtPeriodRange" FontSize="11" Foreground="#B0BEC5" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtTotalHours" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                        <TextBlock Text="Total Hours" FontSize="12" Foreground="#B0BEC5"/>
                    </StackPanel>
                </Border>

                <!-- Messages Preview -->
                <Border Background="#0F3460" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Messages" FontSize="13" FontWeight="Bold" Foreground="#E94560" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtMessagePreview" FontSize="12" Foreground="#B0BEC5"
                                   TextWrapping="Wrap" MaxHeight="80" Margin="0,0,0,8"/>
                        <Button Content="Message Management" Height="36"
                                Background="#E94560" Style="{StaticResource BaseButton}"
                                Click="BtnMessage_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right Panel: Timesheet -->
            <Border Grid.Column="2" Background="#0F3460" CornerRadius="12" Padding="16">
                <StackPanel>
                    <TextBlock Text="My Timesheet — Current Period" FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
                    <DataGrid x:Name="GridPunches" IsReadOnly="True" Height="480"
                              CanUserAddRows="False" CanUserDeleteRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Clock In" Binding="{Binding ClockInTime, StringFormat='MM/dd/yy hh:mm tt'}" Width="*"/>
                            <DataGridTextColumn Header="Clock Out" Binding="{Binding ClockOutDisplay}" Width="*"/>
                            <DataGridTextColumn Header="Duration" Binding="{Binding DurationDisplay}" Width="80"/>
                            <DataGridTextColumn Header="Note" Binding="{Binding InNote}" Width="120"/>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAutoLogout}" Value="True">
                                        <Setter Property="Background" Value="#BF360C"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
