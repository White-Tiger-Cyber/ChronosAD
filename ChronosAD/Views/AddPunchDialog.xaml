<Window x:Class="ChronosAD.Views.AddPunchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Punch" Width="440" Height="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1A1A2E">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TxtEmployeeName"
                   FontSize="16" FontWeight="Bold" Foreground="#E94560"/>

        <StackPanel Grid.Row="2">
            <Label Content="Clock In (MM/dd/yyyy HH:mm):" Margin="0,0,0,6"/>
            <TextBox x:Name="TxtClockIn"/>
        </StackPanel>

        <StackPanel Grid.Row="4">
            <Label Content="Clock Out (MM/dd/yyyy HH:mm, leave blank if still active):" Margin="0,0,0,6"/>
            <TextBox x:Name="TxtClockOut"/>
        </StackPanel>

        <StackPanel Grid.Row="6">
            <Label Content="Note (optional):" Margin="0,0,0,6"/>
            <TextBox x:Name="TxtNote"/>
        </StackPanel>

        <TextBlock Grid.Row="8"
                   Text="This punch will be added to the employee's record."
                   FontSize="11" Foreground="#FFA726" FontStyle="Italic"/>

        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="90" Height="36"
                    Background="#37474F" Style="{StaticResource BaseButton}"
                    Click="BtnCancel_Click" Margin="0,0,10,0"/>
            <Button Content="Save" Width="90" Height="36"
                    Background="#E94560" Style="{StaticResource BaseButton}"
                    Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
