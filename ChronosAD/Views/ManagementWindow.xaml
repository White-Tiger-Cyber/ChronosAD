<Window x:Class="ChronosAD.Views.ManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ChronosAD — Management Console"
        Width="1100" Height="840" MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#0F3460">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Management Console" FontSize="20" FontWeight="Bold"
                           Foreground="#E94560" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Refresh" Width="90" Height="34"
                            Background="#37474F" Style="{StaticResource BaseButton}"
                            Click="BtnRefresh_Click" Margin="0,0,10,0"/>
                    <Button Content="Auto Clock-Out All" Width="140" Height="34"
                            Background="#BF360C" Style="{StaticResource BaseButton}"
                            Click="BtnAutoClockOut_Click" Margin="0,0,10,0"/>
                    <Button Content="Archive Data" Width="110" Height="34"
                            Background="#37474F" Style="{StaticResource BaseButton}"
                            Click="BtnArchive_Click" Margin="0,0,10,0"/>
                    <Button Content="Export CSV" Width="100" Height="34"
                            Background="#37474F" Style="{StaticResource BaseButton}"
                            Click="BtnExport_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Background="#1A1A2E" BorderBrush="#E94560"
                    Margin="16">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#0F3460"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontFamily" Value="Segoe UI"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Padding" Value="16,8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="TabBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="#E94560"
                                        BorderThickness="1,1,1,0"
                                        CornerRadius="4,4,0,0"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      TextBlock.Foreground="{TemplateBinding Foreground}"
                                                      TextBlock.FontFamily="{TemplateBinding FontFamily}"
                                                      TextBlock.FontSize="{TemplateBinding FontSize}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background" Value="#E94560"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TabBorder" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- Tab 1: Employee Status Dashboard -->
            <TabItem Header="Employee Status">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Employee list -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="All Employees — Current Period"
                                   FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                        <DataGrid Grid.Row="1" x:Name="GridEmployees"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  SelectionChanged="GridEmployees_SelectionChanged" Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding User.FullName}" Width="*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="60"/>
                                <DataGridTextColumn Header="Hours" Binding="{Binding TotalHoursDisplay}" Width="70"/>
                                <DataGridTextColumn Header="Frozen" Binding="{Binding User.IsFrozen}" Width="60"/>
                                <DataGridTextColumn Header="Manager" Binding="{Binding IsManagerDisplay}" Width="70"/>
                            </DataGrid.Columns>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsClockedIn}" Value="True">
                                            <Setter Property="Background" Value="#1B5E20"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding User.IsFrozen}" Value="True">
                                            <Setter Property="Background" Value="#37474F"/>
                                            <Setter Property="Foreground" Value="#78909C"/>
                                        </DataTrigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E94560"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <Button Content="Freeze/Unfreeze" Width="140" Height="34"
                                    Background="#546E7A" Style="{StaticResource BaseButton}"
                                    Click="BtnFreeze_Click" Margin="0,0,8,0"/>
                            <Button Content="Promote/Demote" Width="140" Height="34"
                                    Background="#546E7A" Style="{StaticResource BaseButton}"
                                    Click="BtnPromote_Click" Margin="0,0,8,0"/>
                            <Button Content="Delete User" Width="110" Height="34"
                                    Background="#B71C1C" Style="{StaticResource BaseButton}"
                                    Click="BtnDeleteUser_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- Right: Selected Employee Punches -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" x:Name="TxtSelectedEmployee"
                                   Text="Select an employee to view punches"
                                   FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="1" x:Name="TxtPeriodSummary"
                                   Foreground="#B0BEC5" FontSize="12" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="2" x:Name="TxtConfigWarning"
                                   Text="Pay period not configured — set a start date in Payroll Config"
                                   Foreground="#F57F17" FontSize="11" Margin="0,0,0,6"
                                   Visibility="Collapsed"/>
                        <DataGrid Grid.Row="3" x:Name="GridEmployeePunches"
                                  CanUserAddRows="False" CanUserDeleteRows="False" Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Clock In" Binding="{Binding ClockInTime, StringFormat='MM/dd HH:mm'}" Width="*"/>
                                <DataGridTextColumn Header="Clock Out" Binding="{Binding ClockOutDisplay}" Width="*"/>
                                <DataGridTextColumn Header="Hrs" Binding="{Binding DurationDisplay}" Width="65"/>
                                <DataGridTextColumn Header="Auto" Binding="{Binding IsAutoLogout}" Width="40"/>
                            </DataGrid.Columns>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAutoLogout}" Value="True">
                                            <Setter Property="Background" Value="#E65100"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasBadDuration}" Value="True">
                                            <Setter Property="Background" Value="#F57F17"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E94560"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Add Punch" Height="34"
                                    Background="#37474F" Style="{StaticResource BaseButton}"
                                    Click="BtnAddPunch_Click"/>
                            <Button Grid.Column="2" Content="Edit Selected Punch" Height="34"
                                    Background="#E94560" Style="{StaticResource BaseButton}"
                                    Click="BtnEditPunch_Click"/>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Tab 2: Messages -->
            <TabItem Header="Messages">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid Grid.Row="0" x:Name="GridAllMessages"
                              CanUserAddRows="False" CanUserDeleteRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Employee" Binding="{Binding UserName}" Width="120"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding Timestamp, StringFormat='MM/dd HH:mm'}" Width="100"/>
                            <DataGridTextColumn Header="Message" Binding="{Binding EmployeeMessage}" Width="*"/>
                            <DataGridTextColumn Header="Response" Binding="{Binding ManagerResponse}" Width="*"/>
                            <DataGridTextColumn Header="Read" Binding="{Binding IsRead}" Width="50"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Grid.Row="1" Text="Your Response:" FontSize="13" Foreground="#B0BEC5" Margin="0,12,0,4"/>
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Delete Message" Width="140" Height="40"
                                Background="#B71C1C" Style="{StaticResource BaseButton}"
                                Click="BtnDeleteMessage_Click"/>
                        <TextBox Grid.Column="2" x:Name="TxtManagerResponse" Height="40"/>
                        <Button Grid.Column="4" Content="Send Reply" Height="40"
                                Background="#E94560" Style="{StaticResource BaseButton}"
                                Click="BtnReply_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Tab 3: Payroll Config -->
            <TabItem Header="Payroll Config">
                <StackPanel Margin="20" MaxWidth="500" HorizontalAlignment="Left">
                    <TextBlock Text="Pay Period Settings" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,16"/>
                    <StackPanel Margin="0,0,0,16">
                        <Label Content="Pay Period Start Date (14-day cycles begin from this date):" Margin="0,0,0,6"/>
                        <DatePicker x:Name="DpPayPeriodStart"
                                    Background="#0F3460" Foreground="White"
                                    BorderBrush="#E94560"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,16">
                        <Label Content="Holidays (one date per line, format: MM-DD-YYYY):" Margin="0,0,0,6"/>
                        <TextBox x:Name="TxtHolidays" Height="160"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                    <Button Content="Save Configuration" Height="40" Width="200"
                            Background="#E94560" Style="{StaticResource BaseButton}"
                            HorizontalAlignment="Left"
                            Click="BtnSaveConfig_Click" Margin="0,0,0,16"/>
                    <TextBlock x:Name="TxtConfigStatus" FontSize="12" Foreground="#4CAF50"/>
                </StackPanel>
            </TabItem>

            <!-- Tab 4: Punch History -->
            <TabItem Header="Punch History">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Employee selector -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Employee:" Foreground="White" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="CboHistoryEmployee" Width="220" Height="32"
                                  DisplayMemberPath="User.FullName"
                                  SelectionChanged="CboHistoryEmployee_SelectionChanged"/>
                    </StackPanel>

                    <!-- Two-column layout -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="210"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Pay period list -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Pay Periods" FontSize="13" FontWeight="Bold"
                                       Foreground="White" Margin="0,0,0,8"/>
                            <ListBox Grid.Row="1" x:Name="LstPayPeriods"
                                     DisplayMemberPath="Display"
                                     Background="#0F3460" Foreground="White"
                                     BorderBrush="#E94560"
                                     SelectionChanged="LstPayPeriods_SelectionChanged">
                                <ListBox.Resources>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Padding" Value="8,6"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#E94560"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#16213E"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Resources>
                            </ListBox>
                        </Grid>

                        <!-- Right: Punches for selected period -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" x:Name="TxtHistoryHeader"
                                       Text="Select an employee and pay period"
                                       FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                            <DataGrid Grid.Row="1" x:Name="GridHistoryPunches"
                                      CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Clock In" Binding="{Binding ClockInTime, StringFormat='MM/dd HH:mm'}" Width="*"/>
                                    <DataGridTextColumn Header="Clock Out" Binding="{Binding ClockOutDisplay}" Width="*"/>
                                    <DataGridTextColumn Header="Hrs" Binding="{Binding DurationDisplay}" Width="65"/>
                                    <DataGridTextColumn Header="Auto" Binding="{Binding IsAutoLogout}" Width="50"/>
                                    <DataGridTextColumn Header="Note" Binding="{Binding InNote}" Width="120"/>
                                </DataGrid.Columns>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAutoLogout}" Value="True">
                                                <Setter Property="Background" Value="#E65100"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding HasBadDuration}" Value="True">
                                                <Setter Property="Background" Value="#F57F17"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#E94560"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                            </DataGrid>
                            <TextBlock Grid.Row="2" x:Name="TxtHistorySummary"
                                       Foreground="#B0BEC5" FontSize="13" FontWeight="Bold"
                                       Margin="0,8,0,0"/>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
