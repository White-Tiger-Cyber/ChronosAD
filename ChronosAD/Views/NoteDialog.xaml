<Window x:Class="ChronosAD.Views.NoteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Attach Note" Width="420" Height="230"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1A1A2E">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Add a note to this punch (optional):"
                   FontSize="14" Foreground="#B0BEC5"/>
        <TextBox Grid.Row="2" x:Name="TxtNote" Height="70"
                 TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="90" Height="36"
                    Background="#37474F" Style="{StaticResource BaseButton}"
                    Click="BtnCancel_Click" Margin="0,0,10,0"/>
            <Button Content="Attach" Width="90" Height="36"
                    Background="#E94560" Style="{StaticResource BaseButton}"
                    Click="BtnAttach_Click"/>
        </StackPanel>
    </Grid>
</Window>
