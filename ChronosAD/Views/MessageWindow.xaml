<Window x:Class="ChronosAD.Views.MessageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ChronosAD — Messages" Width="620" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Message Thread" FontSize="18" FontWeight="Bold"
                   Foreground="#E94560" Margin="0,0,0,12"/>

        <DataGrid Grid.Row="1" x:Name="GridMessages" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date" Binding="{Binding Timestamp, StringFormat='MM/dd/yy HH:mm'}" Width="110"/>
                <DataGridTextColumn Header="Your Message" Binding="{Binding EmployeeMessage}" Width="*"/>
                <DataGridTextColumn Header="Manager Reply" Binding="{Binding ManagerResponse}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2" Text="New Message:" FontSize="13" Foreground="#B0BEC5" Margin="0,12,0,4"/>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtNewMessage" Height="40"/>
            <Button Grid.Column="2" Content="Send" Height="40"
                    Background="#E94560" Style="{StaticResource BaseButton}"
                    Click="BtnSend_Click"/>
        </Grid>
    </Grid>
</Window>
