<Window x:Class="ChronosAD.Views.PunchEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Punch" Width="440" Height="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1A1A2E">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Edit Punch Record" FontSize="16" FontWeight="Bold"
                   Foreground="#E94560"/>

        <StackPanel Grid.Row="2">
            <Label Content="Clock In (MM/dd/yyyy HH:mm):" Margin="0,0,0,6"/>
            <TextBox x:Name="TxtClockIn"/>
        </StackPanel>

        <StackPanel Grid.Row="4">
            <Label Content="Clock Out (MM/dd/yyyy HH:mm, leave blank if active):" Margin="0,0,0,6"/>
            <TextBox x:Name="TxtClockOut"/>
        </StackPanel>

        <TextBlock Grid.Row="6" x:Name="TxtEditWarning"
                   Text="Original values will be preserved as an audit trail."
                   FontSize="11" Foreground="#FFA726" FontStyle="Italic"/>

        <Grid Grid.Row="8">
            <Button Content="Delete Punch" Width="120" Height="36"
                    Background="#B71C1C" Style="{StaticResource BaseButton}"
                    HorizontalAlignment="Left"
                    Click="BtnDelete_Click"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="90" Height="36"
                        Background="#37474F" Style="{StaticResource BaseButton}"
                        Click="BtnCancel_Click" Margin="0,0,10,0"/>
                <Button Content="Save" Width="90" Height="36"
                        Background="#E94560" Style="{StaticResource BaseButton}"
                        Click="BtnSave_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
